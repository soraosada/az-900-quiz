rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 各ユーザーは自分のドキュメントのみ読み書き可能
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // それ以外はすべて拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
